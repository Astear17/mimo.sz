                                            },
                                            "mode_sdr_only": {
                                                "recv_source": "wlm_share",
                                                "send_target": "wlm_share"
                                            },
                                            "mode_wifi_only": {
                                                "recv_source": "wlm_share",
                                                "send_target": "wlm_share"
                                            }
                                        }
                                }
                    }
                },
                "0x0e07": {
                    "module_name": "WLM_GND",
                    "datas": {
