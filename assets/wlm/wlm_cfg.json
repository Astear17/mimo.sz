                                        "wl_data_type": "liveview1",
                                        "link_number": 2,
                                        "recv_mode": "controlled",
                                        "send_mode": "controlled",
                                        "link_sdr": {
                                                "enable": true,
                                                "input": {"type": "msgq", "host":true, "size": 4096000, "index": 1}
                                        },
                                        "link_lte": {
                                                "enable": true,
                                                "input": {"type": "msgq", "host":true, "size": 4096000, "index": 2}
                                        },
                                        "params":{
                                            "mode_lte_only": {
                                                "recv_source": "wlm_share",
