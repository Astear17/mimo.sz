<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <set>
            <objectAnimator android:duration="0" android:valueTo="12" android:valueType="floatType" android:propertyName="textSize" />
        </set>
    </item>
    <item android:state_selected="false">
        <set>
            <objectAnimator android:duration="0" android:valueTo="10" android:valueType="floatType" android:propertyName="textSize" />
        </set>
    </item>
</selector>
