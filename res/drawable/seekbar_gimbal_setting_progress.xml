<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center_vertical" android:id="@android:id/background" android:height="@dimen/d_6_dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/gray_opacity_22" />
            <corners android:radius="@dimen/d_3_dp" />
        </shape>
    </item>
    <item android:gravity="center_vertical" android:id="@android:id/progress" android:height="@dimen/d_6_dp">
        <clip android:clipOrientation="horizontal">
            <shape android:shape="rectangle">
                <solid android:color="@color/transparent" />
                <corners android:radius="@dimen/d_3_dp" />
            </shape>
        </clip>
    </item>
</layer-list>
