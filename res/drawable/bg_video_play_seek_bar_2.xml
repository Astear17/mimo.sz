<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center_vertical" android:id="@android:id/background" android:height="2.0dp">
        <shape>
            <size android:height="@dimen/d_2_dp" />
            <solid android:color="@color/white_40" />
            <corners android:radius="@dimen/d_1_dp" />
        </shape>
    </item>
    <item android:gravity="center_vertical" android:id="@android:id/progress" android:height="2.0dp">
        <clip>
            <shape>
                <size android:height="@dimen/d_2_dp" />
                <solid android:color="@color/white" />
                <corners android:radius="@dimen/d_1_dp" />
            </shape>
        </clip>
    </item>
</layer-list>
