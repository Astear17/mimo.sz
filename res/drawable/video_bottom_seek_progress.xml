<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="@color/white_20" />
            <size android:height="@dimen/d_2_dp" />
        </shape>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <solid android:color="@color/white_20" />
                <size android:height="@dimen/d_2_dp" />
            </shape>
        </clip>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/d_3_dp" />
                <gradient android:startColor="@android:color/white" android:endColor="@android:color/white" android:angle="360.0" android:type="linear" android:centerColor="@android:color/white" />
                <size android:height="@dimen/d_2_dp" />
            </shape>
        </clip>
    </item>
</layer-list>
