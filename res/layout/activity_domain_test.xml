        <Button android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="确定" android:onClick="onPassWordClick" />
    </LinearLayout>
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/d_30_dp">
        <TextView android:textColor="@color/black" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="用户运行版本：" />
