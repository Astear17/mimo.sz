    <Button android:id="@id/ok_btn" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/d_50_dp" android:text="关闭" android:onClick="onButtonClick" />
    <TextView android:textColor="@color/red_record_pressed" android:gravity="bottom" android:id="@id/env_text" android:paddingBottom="@dimen/text_dp_16" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_weight="1.0" />
