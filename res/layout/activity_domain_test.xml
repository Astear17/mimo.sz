        <TextView android:textColor="@color/red_record_pressed" android:id="@id/usercenter_env" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_weight="1.0" />
    </LinearLayout>
    <TextView android:textColor="@color/red_record_pressed" android:id="@id/usercenter_url" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/d_7_dp" />
