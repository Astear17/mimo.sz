<?xml version="1.0" encoding="utf-8"?>
<FrameLayout android:background="@color/white" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20.0dp">
        <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="20.0dp" android:text="show ai phase" />
            <Button android:id="@id/show_phase" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="unset" android:textAllCaps="false" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="20.0dp" android:text="show sensor log" />
            <Button android:id="@id/show_sensor_log" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="unset" android:textAllCaps="false" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:visibility="visible" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="20.0dp" android:text="show http log" />
            <Button android:id="@id/show_http_log" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="unset" android:textAllCaps="false" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:visibility="visible" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="20.0dp" android:text="ai edit bg" />
            <Button android:id="@id/ai_edit_bg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="unset" android:textAllCaps="false" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="20.0dp" android:text="basic info" />
            <TextView android:id="@id/basic_info" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="unset" android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
