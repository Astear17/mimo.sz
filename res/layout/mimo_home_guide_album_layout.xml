<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:id="@id/home_user_guide_album_container" style="@style/home_user_guide_root_view_style"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <ImageView android:src="@drawable/home_user_guide_item_star" android:layout_above="@id/home_user_guide_album_content_container" style="@style/home_user_guide_star_style" />
    <RelativeLayout android:id="@id/home_user_guide_album_content_container" android:layout_above="@id/home_user_guide_album_content_arrow" style="@style/home_user_guide_content_container_style">
        <ImageView android:id="@id/home_user_guide_album_content_image" android:src="@drawable/home_user_guide_content_icon_album" style="@style/home_user_guide_content_image_style" />
        <TextView android:id="@id/home_user_guide_album_content_title" android:text="@string/mimo_home_teaching_albm_tab_tips_toast_title" android:layout_below="@id/home_user_guide_album_content_image" style="@style/home_user_guide_content_title_style" />
        <TextView android:id="@id/home_user_guide_album_content_description" android:text="@string/mimo_home_teaching_albm_tab_tips_toast_content" android:layout_below="@id/home_user_guide_album_content_title" style="@style/home_user_guide_content_description_style" />
    </RelativeLayout>
    <ImageView android:id="@id/home_user_guide_album_content_arrow" android:layout_above="@id/home_user_guide_album_anchor" android:layout_marginStart="@dimen/d_75_dp" style="@style/home_user_guide_arrow_style" />
    <ImageView android:id="@id/home_user_guide_album_anchor" android:src="@drawable/home_user_guide_item_anchor_album" android:layout_above="@id/home_user_guide_album_bottom_margin_view" android:layout_marginStart="@dimen/d_60_dp" style="@style/home_user_guide_anchor_style" />
    <TextView android:id="@id/home_user_guide_album_bottom_margin_view" style="@style/home_user_guide_bottom_margin_view_style" />
</RelativeLayout>
